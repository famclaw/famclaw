# FamClaw environment variables
# Copy this file: cp .env.example .env
# Then edit with your values.

# Server secret — used for signing approval tokens.
# Auto-generated on first boot if not set.
FAMCLAW_SECRET=

# Parent PIN — set during first-boot wizard or here.
PARENT_PIN=

# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=

# Discord bot token (from Discord Developer Portal)
# DISCORD_BOT_TOKEN=

# Notification channels (all optional)
# EMAIL_FROM=
# EMAIL_PASSWORD=
# PARENT_EMAIL=
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# PARENT_PHONE=
# NTFY_TOPIC=famclaw-alerts
# NTFY_TOKEN=

# MCP server auth (if using remote HTTP MCP)
# MCP_TOKEN=
